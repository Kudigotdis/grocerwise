  },

  "motsheloEngine": {
    "states": ["DRAFT", "LOCKED", "ACTIVE", "VOTING", "RESERVING", "FULL", "READY_TO_EXECUTE", "EXECUTED"],
    "confirmationRule": 4,
    "minimumMembers": 10,
    "maximumMembers": 50,
    "quorumPercentage": 50,
    "features": {
      "memberManagement": {
        "display": "Member list with contributions",
        "info": "Name, role, network, location, weeks paid, status"
      },
      "voting": {
        "display": "Vote card with progress",
        "actions": ["YES", "NO", "ABSTAIN"],
        "info": "Beast, cost, deadline, votes breakdown"
      },
      "borrow": {
        "display": "Request cards with confirmations",
        "info": "Member, amount, reason, repay date, confirmations (4 dots)"
      },
      "stock": {
        "display": "Beast cards with slot tracking",
        "info": "Beast ID, type, weight, price, registered, remaining"
      }
    }
  },

  "vendorKPI": {
    "metrics": [
      {"id": "itemViews", "label": "Item Views Today", "trend": "up/down"},
      {"id": "itemsAdded", "label": "Items Added to Sums", "trend": "up/down"},
      {"id": "avgBudget", "label": "Avg User Budget", "trend": "up/down"},
      {"id": "peakDay", "label": "Peak Purchase Day", "trend": "neutral"},
      {"id": "topCity", "label": "Top Sales City", "trend": "up/down"},
      {"id": "popularShare", "label": "Most Popular Share", "trend": "up/down"},
      {"id": "abandonedSums", "label": "Abandoned Sums", "trend": "down"},
      {"id": "repeatCustomers", "label": "Repeat Customers", "trend": "up/down"},
      {"id": "subscription", "label": "Platform Subscription", "trend": "fixed"},
      {"id": "monthlyProfit", "label": "Monthly Profit Est.", "trend": "up/down"},
      {"id": "contributionScore", "label": "Contribution Score", "trend": "up/down"},
      {"id": "communityRating", "label": "Community Rating", "trend": "up/down"}
    ],
    "heatmap": {
      "display": "28-cell grid (4 weeks)",
      "interpretation": "Darker = higher demand",
      "grouping": "By city/neighborhood"
    }
  },

  "dataStructures": {
    "appState": {
      "keys": ["currentProfile", "sum", "user", "customItems", "currentView", "activeCat"],
      "persistence": "localStorage (key: namatose_v2)"
    },
    "sum": {
      "fields": ["name", "budget", "schedule", "items[]"],
      "computed": "remaining = budget - (items × price)"
    },
    "items": {
      "fields": ["id", "cat", "name", "price", "unit", "vendor", "emoji", "cut", "desc", "shareType", "slots", "slotsFilled", "beastId"],
      "total": 37
    },
    "beasts": {
      "fields": ["id", "type", "breed", "weight", "priceKg", "distMode", "sharePeople", "vendor", "city"],
      "shareCalculation": {
        "markup": "7.5%",
        "largeSlots": 10,
        "largeKg": 10,
        "medSlots": 15,
        "medKg": 5,
        "smallKg": 2.5
      }
    }
  },

  "integration": {
    "whatsapp": {
      "deepLink": "https://wa.me/",
      "usage": "Share sums, promos, contact vendors"
    },
    "facebook": {
      "deepLink": "https://facebook.com/",
      "usage": "Vendor gallery links"
    },
    "offline": {
      "storage": "localStorage",
      "key": "namatose_v2",
      "behavior": "Persist user, sum, custom items on change"
