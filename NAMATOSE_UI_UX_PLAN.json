    "motshelo_manager": {
      "profile": "motshelo_mgr",
      "steps": [
        {"action": "Login as Manager", "screen": "loginScreen"},
        {"action": "Navigate to Profile", "screen": "view-profile"},
        {"action": "Expand Motshelo", "result": "Manager features visible"},
        {"action": "Create Vote", "action": "tap '+ Create New Vote'"},
