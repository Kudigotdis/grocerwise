{
  "platform": {
    "name": "Namatose",
    "version": "2.0",
    "architecture": "Bothoflow™",
    "designSystem": "SNIS (Sums / Notes / Items)",
    "designPhilosophy": "Accordion-based single-page expandable",
    "platform": "Offline-first HTML Android WebApp (PWA)",
    "region": "Botswana",
    "partners": ["BTC Smega", "Mascom MyZaka", "Orange Money"]
  },

  "pageTally": {
    "totalScreens": 2,
    "totalViews": 4,
    "totalSlidePanels": 4,
    "totalOverlayComponents": 3,
    "totalProfileTypes": 8,
    "totalAccordionSections": 15,
    "grandTotal": 13
  },

  "screens": {
    "1_login": {
      "id": "loginScreen",
      "type": "full-screen",
      "access": "public",
      "purpose": "Entry point / Authentication",
      "wireframe": {
        "layout": "centered-card",
        "background": "forest-green gradient with radial accents",
        "elements": [
          {"type": "logo-mark", "content": "🥩", "size": "72px"},
          {"type": "brand-title", "content": "NAMATOSE"},
          {"type": "tagline", "content": "Community Feeds Platform · Botswana"},
          {"type": "login-card", "fields": ["First Name", "WhatsApp Number", "Password"]},
          {"type": "submit-button", "label": "ENTER NAMATOSE →"},
          {"type": "partner-tags", "content": "🔷 BTC 🔴 Mascom 🟠 Orange"},
          {"type": "footer", "content": "© 2025 Namatose · Bothoflow™ Protected"}
        ]
      },
      "ux": {
        "prefilled": {"firstName": "Paphani", "whatsapp": "+267 71 234 567", "password": "demo2025"},
        "behavior": "Any credentials work (Browser mode)",
        "onSuccess": "Navigate to appScreen, persist to localStorage"
      }
    },

    "2_appShell": {
      "id": "appScreen",
      "type": "container",
      "access": "authenticated",
      "purpose": "Main app wrapper with 4-level structure",
      "wireframe": {
        "layout": "4-level-deep",
        "level1": {
          "id": "topHeader",
          "position": "fixed-top",
          "behavior": "hides on scroll",
          "elements": ["logo", "page-name", "profile-btn", "share-btn"]
        },
        "level2": {
          "id": "sumHeader",
          "position": "below header",
          "behavior": "expandable accordion",
          "collapsed": "budget summary",
          "expanded": "item list + actions"
        },
        "level3": {
          "id": "noteBody",
          "position": "scrollable content",
          "contains": ["view-items", "view-promos", "view-notices", "view-profile"]
        },
        "level4": {
          "id": "bottomNav",
          "position": "fixed-bottom",
          "tabs": ["items", "promos", "notices", "profile"]
        }
      }
    }
  },

  "views": {
    "view_items": {
      "id": "view-items",
      "label": "Items",
      "icon": "🥩",
      "purpose": "Main product catalog",
      "wireframe": {
        "header": "🔥 Live Deals & Promotions",
        "components": [
          {"id": "catPills", "type": "horizontal-scroll", "count": 9},
          {"id": "categoryCards", "type": "accordion", "count": 8},
          {"id": "beastSection", "type": "expandable"},
          {"id": "inventorySection", "type": "expandable"}
        ]
      },
      "categories": [
        {"id": "beef", "emoji": "🥩", "items": 12},
        {"id": "goat", "emoji": "🐐", "items": 5},
        {"id": "chicken", "emoji": "🍗", "items": 5},
        {"id": "game", "emoji": "🦌", "items": 6},
        {"id": "pork", "emoji": "🐷", "items": 2},
        {"id": "sheep", "emoji": "🍖", "items": 2},
        {"id": "groceries", "emoji": "🛒", "items": 7},
        {"id": "services", "emoji": "⚙️", "items": 2}
      ],
      "beasts": [
        {"id": "Beast01", "type": "Cow - Nguni", "weight": "250kg", "slots": 55},
        {"id": "PiggyOink43", "type": "Pig - Landrace", "weight": "237kg", "slots": 49},
        {"id": "giffy45", "type": "Game - Impala", "weight": "190.5kg", "slots": 31}
      ],
      "ux": {
        "filterBehavior": "Tap category pill to filter",
        "expandBehavior": "Tap card header to toggle",
        "itemTap": "Opens itemDetailPanel",
        "vendorStrip": "Appears below each category"
      }
    },

    "view_promos": {
      "id": "view-promos",
      "label": "Promos",
      "icon": "🔥",
      "purpose": "Deals and promotions",
      "wireframe": {
        "layout": "vertical-card-stack",
        "components": [
          {"type": "promo-card", "count": 5}
        ]
      },
      "promos": [
        {"title": "10% OFF Rump Steak", "code": "NAMATOSE10", "vendor": "86th Ave Butchery"},
        {"title": "Free Delivery on Group Orders", "code": "GRPFREE", "vendor": "Ditiro Transport"},
        {"title": "P50 Rebate - First Group", "code": "MOTSHELO50", "vendor": "Namatose"},
        {"title": "Zero Fees Weekend - MyZaka", "code": "MYZAKAZERO", "vendor": "Mascom"},
        {"title": "Fresh Spinach - Buy 3 Get 1", "code": "SPINACH4", "vendor": "Oodi Farm"}
      ],
      "ux": {
        "shareBehavior": "Tap share button → WhatsApp deep link"
      }
    },

    "view_notices": {
      "id": "view-notices",
      "label": "Notices",
      "icon": "📋",
      "purpose": "Notice board with vendor posts",
      "wireframe": {
        "layout": "vertical-card-stack",
        "components": [
          {"type": "notice-card", "count": 6}
        ]
      },
      "noticeTypes": [
        {"type": "stock", "icon": "🔥"},
        {"type": "event", "icon": "📅"},
        {"type": "service", "icon": "❄️"},
        {"type": "produce", "icon": "🌱"},
        {"type": "group", "icon": "🐃"}
      ],
      "ux": {
        "whatsappBtn": "Tap to open WhatsApp",
        "fbGalleryBtn": "Tap to open Facebook"
      }
    },

    "view_profile": {
      "id": "view-profile",
      "label": "Profile",
      "icon": "👤",
      "purpose": "User profile + settings + Motshelo + Vendor KPI",
      "wireframe": {
        "components": [
          {"id": "profileHero", "type": "header"},
          {"id": "psect-personal", "type": "accordion", "label": "Personal Details"},
          {"id": "psect-money", "type": "accordion", "label": "Mobile Money"},
          {"id": "psect-perms", "type": "accordion", "label": "Profile Permissions"},
          {"id": "psect-sums", "type": "accordion", "label": "My Sums"},
          {"id": "psect-motshelo", "type": "accordion", "label": "Motshelo", "tabs": 4},
          {"id": "psect-kpis", "type": "accordion", "label": "Vendor KPI", "conditional": true},
          {"id": "psect-stock", "type": "accordion", "label": "Stock Inventory", "conditional": true}
        ]
      },
      "motsheloTabs": [
        {"id": "members", "label": "Members", "count": 12},
        {"id": "vote", "label": "Vote", "state": "OPEN"},
        {"id": "borrow", "label": "Borrow", "requests": 2},
        {"id": "inventory", "label": "Stock", "beasts": 3}
      ],
      "ux": {
        "accordionBehavior": "Tap header to expand/collapse",
        "saveBehavior": "Save to localStorage on button click",
        "profileSwitch": "Opens profileSwitcherPanel"
      }
    }
  },

  "slidePanels": {
    "profileSwitcherPanel": {
      "id": "profileSwitcherPanel",
      "trigger": "Top header profile button OR profile section",
      "purpose": "Change user role/permissions",
      "wireframe": {
        "layout": "vertical-list",
        "items": [
          {"emoji": "👨🏾", "name": "Paphani Masalila", "badge": "User"},
          {"emoji": "👩🏾", "name": "Kefilwe Sebele", "badge": "User"},
          {"emoji": "🏦", "name": "Paphani Masalila", "badge": "Manager"},
          {"emoji": "🔪", "name": "86th Ave Butchery", "badge": "Vendor"},
          {"emoji": "❄️", "name": "CoolChain Services", "badge": "Supplier"},
          {"emoji": "🛒", "name": "Fresh Picks Market", "badge": "Vendor"},
          {"emoji": "⚙️", "name": "Developer Admin", "badge": "Admin"},
          {"emoji": "🌐", "name": "Browser User", "badge": "Free"}
        ]
      },
      "ux": {
        "tapAction": "Switches profile, closes panel, re-renders profile view"
      }
    },

    "itemDetailPanel": {
      "id": "itemDetailPanel",
      "trigger": "Tap item card in Items View",
      "purpose": "View item details, add to sum, contact vendor",
      "wireframe": {
        "layout": "vertical-stack",
        "sections": [
          {"id": "imageArea", "height": "170px"},
          {"id": "infoRows", "fields": ["Price", "Vendor", "Category"]},
          {"id": "shareOptions", "conditional": "only for beasts"},
          {"id": "paymentTags", "options": ["Cash", "BTC", "MyZaka", "Orange"]},
          {"id": "actionButtons", "buttons": ["Add to Sum", "WhatsApp", "Facebook"]}
        ]
      },
      "ux": {
        "shareToggle": "Tap to select Large/Med/Small",
        "addToSum": "Adds item, closes panel, shows toast",
        "whatsapp": "Opens WhatsApp with vendor number",
        "facebook": "Opens Facebook gallery"
      }
    },

    "createItemPanel": {
      "id": "createItemPanel",
      "trigger": "Tap '+ Create' pill in Items View",
      "purpose": "Add custom item to catalog",
      "wireframe": {
        "layout": "form-stack",
        "fields": [
          {"id": "photo", "type": "upload", "label": "Tap to add photo"},
          {"id": "name", "type": "text", "required": true},
          {"id": "category", "type": "select", "options": ["Beef", "Goat", "Chicken", "Game", "Pork", "Sheep/Lamb", "Groceries", "Services"]},
          {"id": "price", "type": "number", "required": true},
          {"id": "unit", "type": "text"},
          {"id": "vendor", "type": "text"},
          {"id": "cut", "type": "select"},
          {"id": "distribution", "type": "select"},
          {"id": "description", "type": "textarea"},
          {"id": "publish", "type": "checkbox", "label": "Publish to community"}
        ],
        "buttons": ["Cancel", "Save Item"]
      },
      "ux": {
        "validation": "Name and price required",
        "photoPreview": "Shows uploaded image",
        "saveAction": "Adds to APP.customItems, re-renders items"
      }
    },

    "newSumPanel": {
      "id": "newSumPanel",
      "trigger": "Profile → My Sums OR Sum Header → New Sum",
      "purpose": "Create or load budget",
      "wireframe": {
        "layout": "tabbed-panel",
        "tabs": [
          {"id": "create", "label": "New Sum"},
          {"id": "saved", "label": "My Saved Sums"}
        ],
        "createFields": [
          {"id": "name", "type": "text", "placeholder": "e.g. Family Monthly Budget"},
          {"id": "budget", "type": "number", "placeholder": "0.00"},
          {"id": "schedule", "type": "select", "options": ["Daily", "Scheduled Day", "Weekly", "Monthly"]}
        ],
        "savedSums": [
          {"name": "Weekly Household", "budget": 1500, "schedule": "Weekly"},
          {"name": "Monthly Beef Share", "budget": 3200, "schedule": "Monthly"},
          {"name": "Diet Plan - Jan", "budget": 2000, "schedule": "Monthly"},
          {"name": "Braai Weekend", "budget": 800, "schedule": "Scheduled Day"},
          {"name": "Kids' Monthly", "budget": 1200, "schedule": "Monthly"},
          {"name": "Game Night Special", "budget": 2500, "schedule": "Scheduled Day"},
          {"name": "Motshelo Commitment", "budget": 400, "schedule": "Monthly"}
        ]
      },
      "ux": {
        "tabSwitch": "Tap tab to switch between create/saved",
        "loadAction": "Loads sum to active, updates sum header",
        "createAction": "Creates new sum, closes panel, updates header"
      }
    }
  },

  "overlayComponents": {
    "sumHeader": {
      "id": "sumHeader",
      "position": "Level 2 (below top header)",
      "behavior": "expandable accordion",
      "collapsed": {
        "layout": "horizontal",
        "elements": ["budget name", "remaining amount", "used amount"]
      },
      "expanded": {
        "layout": "vertical-stack",
        "elements": [
          {"id": "progressBar", "type": "percentage fill"},
          {"id": "itemList", "type": "scrollable list", "itemActions": ["remove"]},
          {"id": "actionButtons", "buttons": ["Reset", "New Sum", "Share"]}
        ]
      },
      "ux": {
        "tapToExpand": "Tap sum bar to toggle",
        "autoCalculate": "Updates remaining on item add/remove",
        "shareAction": "Generates WhatsApp message with sum breakdown"
      }
    },

    "toast": {
      "id": "toast",
      "position": "fixed bottom center",
      "behavior": "auto-dismiss after 2.8s",
      "wireframe": {
        "layout": "rounded-rectangle",
        "style": "dark background, white text"
      },
      "ux": {
        "show": "opacity: 1, translateY(0)",
        "hide": "opacity: 0, translateY(10px)",
        "duration": 2800
      }
    },

    "overlay": {
      "id": "overlay",
      "position": "full-screen backdrop",
      "behavior": "click to close panels",
      "wireframe": {
        "layout": "full-screen",
        "style": "semi-transparent dark (rgba(10,20,14,0.6))",
        "blur": "2px backdrop-filter"
      },
      "ux": {
        "show": "displays behind slide panels",
        "tapAction": "Closes all panels"
      }
    }
  },

